@model Common.AddBloodStockViewModel

<div class="container d-flex justify-content-center my-5">

    <div class="card shadow-lg border-0" style="width: 450px; border-top:4px solid #dc3545;">

        <div class="card-header bg-white text-center">
            <h4 class="text-danger mb-0">Add Blood Stock</h4>
        </div>

        <div class="card-body">

            <form method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label class="form-label">Blood Type</label>
                    <select class="form-control form-select" asp-for="BloodTypeId">

                        @foreach (var list in _staticListService.BloodTypes())
                        {
                            <option value="@list.Value">@list.Text</option>
                        }

                    </select>
                    <span asp-validation-for="BloodTypeId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Quantity</label>
                    <input type="number" class="form-control" asp-for="Quantity" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100">
                    Add Stock
                </button>

            </form>

        </div>

    </div>

</div>