@model Common.ResetPassword

<style>
    body {
        background: #f8f9fa;
    }

    .blood-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
    }

    .blood-header {
        background: linear-gradient(135deg, #dc3545, #a71d2a);
        color: white;
        padding: 18px;
        text-align: center;
        font-weight: bold;
        font-size: 20px;
    }

    .btn-blood {
        background: #dc3545;
        color: white;
        border-radius: 8px;
    }

    .btn-blood:hover {
        background: #a71d2a;
        color: white;
    }

    .form-control:focus {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.2rem rgba(220,53,69,0.15);
    }
</style>

<div class="d-flex justify-content-center align-items-center py-5" style="min-height:80vh;">
    <div class="card blood-card shadow-lg w-100" style="max-width:420px;">

        <div class="blood-header">
            Reset Your Password
        </div>

        <div class="card-body p-4">

            @if (ViewBag.message != null)
            {
                <div class="text-danger text-center mb-3">
                    @ViewBag.message
                </div>
            }

            <form method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="ResetToken" />

                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <input type="password" asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-blood w-100">
                    Reset Password
                </button>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}