@model List<Common.BloodRequestViewModel>

<div class="container my-4">

    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">My Blood Requests</h5>
            <a asp-controller="BloodRequest" asp-action="RequestBlood" class="btn btn-light btn-sm text-danger fw-semibold">
                + Request Blood
            </a>
        </div>

        <div class="card-body">

            <table class="table table-hover align-middle" id="example">
                <thead class="table-danger text-dark">
                    <tr>
                        <th>S.N</th>
                        <th>Blood Type</th>
                        <th>Urgency</th>
                        <th>Quantity</th>
                        <th>Required Date</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null)
                    {
                        for (var i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td><span class="badge bg-danger">@Model[i].BloodType</span></td>
                                <td>@Model[i].UrgencyType</td>
                                <td>@Model[i].Quantity</td>
                                <td>@Model[i].RequiredDate</td>
                                <td>@Model[i].Location</td>
                                <td>
                                    @if (Model[i].Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (Model[i].Status == "Completed")
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@Model[i].Status</span>
                                    }
                                </td>

                                <td>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-danger dropdown-toggle" data-bs-toggle="dropdown">
                                            Action
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <a class="dropdown-item"
                                                   asp-action="Edit"
                                                   asp-controller="BloodRequest"
                                                   asp-route-BloodRequestId="@Model[i].BloodRequestId">
                                                    Edit
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item text-danger"
                                                   asp-action="Delete"
                                                   asp-controller="BloodRequest"
                                                   asp-route-BloodRequestId="@Model[i].BloodRequestId">
                                                    Delete
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>

<script>
    new DataTable('#example', {
        rowReorder: true
    });
</script>