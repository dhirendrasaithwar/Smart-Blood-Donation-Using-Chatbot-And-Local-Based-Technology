@model List<Common.BloodTypeViewModel>

<div class="container my-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Blood Types</h5>

            <a asp-controller="BloodType" asp-action="Create" class="btn btn-light btn-sm text-danger fw-semibold">
                + Create
            </a>
        </div>

        <div class="card-body">

            <table class="table table-hover align-middle" id="example">

                <thead class="table-danger text-dark">
                    <tr>
                        <th>S.N</th>
                        <th>Blood Type</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>

                    @for (var i = 0; i < Model.Count; i++)
                    {
                        <tr>
                            <td>@(i + 1)</td>

                            <td>
                                <span class="badge bg-danger fs-6">
                                    @Model[i].BloodTypes
                                </span>
                            </td>

                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-danger dropdown-toggle"
                                            data-bs-toggle="dropdown">
                                        Action
                                    </button>

                                    <ul class="dropdown-menu">

                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="BloodType"
                                               asp-action="Edit"
                                               asp-route-BloodTypeId="@Model[i].BloodTypeId">
                                                Edit
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item text-danger"
                                               asp-controller="BloodType"
                                               asp-action="Delete"
                                               asp-route-BloodTypeId="@Model[i].BloodTypeId">
                                                Delete
                                            </a>
                                        </li>

                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<script>
    new DataTable('#example', {
        rowReorder: true
    });
</script>